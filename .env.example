SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# Or set SUPABASE_DB_PASSWORD instead of embedding in DATABASE_URL (Supabase → Settings → Database)
SUPABASE_DB_PASSWORD=your-database-password
AUTO_DB_MIGRATE=true

# Google Gemini (analyze with PDF inline)
GEMINI_API_KEY=your-gemini-key
GEMINI_DEFAULT_MODEL=gemini-3.5-flash

# Azure OpenAI (prompt-only analyze — gpt-4o, gpt-4o-mini, gpt-3.5-turbo, gpt-5)
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_GPT_4O=your-gpt-4o-deployment
AZURE_OPENAI_DEPLOYMENT_GPT_4O_MINI=your-gpt-4o-mini-deployment
AZURE_OPENAI_DEPLOYMENT_GPT_35=your-gpt-35-deployment
AZURE_OPENAI_DEPLOYMENT_GPT_5=your-gpt-5-deployment

# Landing AI — Agentic Document Extraction (gov + internal point parsing)
VISION_AGENT_API_KEY=your-landing-ai-api-key
LANDING_AI_API_BASE=https://api.va.landing.ai
LANDING_AI_PARSE_MODEL=dpt-2-latest
LANDING_AI_EXTRACT_MODEL=extract-latest

PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
DEFAULT_PDF_PATH=C:\\Users\\Hp\\Downloads\\bundle\\I M P T F S.pdf
