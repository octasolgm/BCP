apps/api/generated/*
!apps/api/generated/.gitkeep

# Client Documents — subfolders with large uploads stay local unless added explicitly
docs/client-documents/requirement-files/*
docs/client-documents/internal-process-docs/*
docs/client-documents/sample-excel-sheets/*
docs/client-documents/sample-output-templates/*
!docs/client-documents/requirement-files/.gitkeep
