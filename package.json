{
  "name": "bcp",
  "version": "1.0.0",
  "private": true,
  "description": "Bank Compliance Platform - AI-Powered Regulatory Gap Analysis",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "db:migrate": "npm run db:migrate --workspace=apps/api",
    "db:seed": "npm run seed:landing-ai --workspace=apps/api",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "rimraf node_modules apps/*/node_modules apps/*/dist apps/*/.next packages/*/node_modules packages/*/dist"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  },
  "author": "BCP Development Team",
  "license": "UNLICENSED"
}
